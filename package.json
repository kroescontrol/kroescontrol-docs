{
  "name": "kroescontrol-docs",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "node generate-sidebar.js && docusaurus start",
    "start:public": "PUBLIC_ONLY=true node generate-sidebar.js && PUBLIC_ONLY=true docusaurus start",
    "build": "node generate-sidebar.js && docusaurus build",
    "build:public": "PUBLIC_ONLY=true node generate-sidebar.js && PUBLIC_ONLY=true docusaurus build --config docusaurus.config.js",
    "clear": "docusaurus clear && rm -rf .docusaurus && rm -rf node_modules/.cache",
    "swizzle": "docusaurus swizzle",
    "deploy": "node generate-sidebar.js && docusaurus deploy",
    "deploy:public": "./deploy-public.sh",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "^3.0.0",
    "@docusaurus/mdx-loader": "^3.0.0",
    "@docusaurus/plugin-client-redirects": "^3.7.0",
    "@docusaurus/preset-classic": "^3.0.0",
    "@mdx-js/loader": "^3.0.0",
    "@mdx-js/react": "^3.0.0",
    "@svgr/webpack": "^8.0.1",
    "clsx": "^2.0.0",
    "docusaurus-plugin-chat-page": "^0.1.6",
    "dotenv": "^16.5.0",
    "file-loader": "^6.2.0",
    "prism-react-renderer": "^2.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "url-loader": "^4.1.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
