{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "installCommand": "npm ci",
  "framework": null,
  "functions": {
    "api/auth.js": {
      "runtime": "nodejs18.x"
    }
  },
  "env": {
    "OAUTH_CLIENT_ID": "$OAUTH_CLIENT_ID",
    "OAUTH_CLIENT_SECRET": "$OAUTH_CLIENT_SECRET", 
    "ACCESS_TOKEN": "$ACCESS_TOKEN"
  }
}