{
  "buildCommand": "npm run build",
  "outputDirectory": "build", 
  "installCommand": "npm ci",
  "framework": null,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/api/?path=$1" }
  ],
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node@3.2.21",
      "includeFiles": "build/**"
    }
  }
}