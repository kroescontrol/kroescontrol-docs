{
  "buildCommand": "npm run build",
  "outputDirectory": "build", 
  "installCommand": "npm ci",
  "framework": null,
  "functions": {
    "api/auth.js": {
      "runtime": "@vercel/node@3.2.21"
    }
  },
  "rewrites": [
    {
      "source": "/internal/:path*",
      "destination": "/api/secure-proxy?path=/internal/:path*"
    },
    {
      "source": "/operation/:path*", 
      "destination": "/api/secure-proxy?path=/operation/:path*"
    },
    {
      "source": "/finance/:path*",
      "destination": "/api/secure-proxy?path=/finance/:path*"
    }
  ],
  "env": {
    "OAUTH_CLIENT_ID": "$OAUTH_CLIENT_ID",
    "OAUTH_CLIENT_SECRET": "$OAUTH_CLIENT_SECRET", 
    "ACCESS_TOKEN": "$ACCESS_TOKEN"
  }
}