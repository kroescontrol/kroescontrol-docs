{
  "buildCommand": "npm run build",
  "outputDirectory": "build", 
  "installCommand": "npm ci",
  "framework": null,
  "routes": [
    { "src": "/api/debug", "dest": "/api/debug" },
    { "src": "/login/oauth/authorize", "dest": "/api/index" },
    { "src": "/login/oauth/callback", "dest": "/api/index" },
    { "src": "/internal/(.*)", "dest": "/api/internal?path=$1" },
    { "src": "/finance/(.*)", "dest": "/api/finance?path=$1" },
    { "src": "/operation/(.*)", "dest": "/api/operation?path=$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/api/public?path=$1" }
  ],
  "functions": {
    "api/public.js": {
      "runtime": "@vercel/node@3.2.21",
      "includeFiles": "build/**"
    },
    "api/index.js": {
      "runtime": "@vercel/node@3.2.21",
      "includeFiles": "build/**"
    },
    "api/internal.js": {
      "runtime": "@vercel/node@3.2.21",
      "includeFiles": "build/internal/**"
    },
    "api/finance.js": {
      "runtime": "@vercel/node@3.2.21",
      "includeFiles": "build/finance/**"
    },
    "api/operation.js": {
      "runtime": "@vercel/node@3.2.21",
      "includeFiles": "build/operation/**"
    }
  }
}