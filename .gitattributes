# Markdown bestanden hebben LF line endings
*.md text eol=lf
*.mdx text eol=lf

# Git-crypt configuratie voor versleutelde bestanden
# Default key: internal documenten (alle medewerkers)
/docs-internal/**/*.md filter=git-crypt diff=git-crypt
/docs-internal/**/*.mdx filter=git-crypt diff=git-crypt

# Temporary: use default key for operation en finance (same as internal)
/docs-operation/**/*.md filter=git-crypt diff=git-crypt
/docs-operation/**/*.mdx filter=git-crypt diff=git-crypt
/docs-finance/**/*.md filter=git-crypt diff=git-crypt
/docs-finance/**/*.mdx filter=git-crypt diff=git-crypt

# Versleutel _category_.json bestanden in gevoelige mappen
# Default key: internal
/docs-internal/**/_category_.json filter=git-crypt diff=git-crypt

# Temporary: use default key for operation en finance
/docs-operation/**/_category_.json filter=git-crypt diff=git-crypt
/docs-finance/**/_category_.json filter=git-crypt diff=git-crypt

# Versleutel .meta directories en bestanden in gevoelige categorieën
# Gebruik expliciete patterns omdat git-crypt problemen heeft met complexe wildcards
/docs-internal/.meta/** filter=git-crypt diff=git-crypt
/docs-operation/.meta/** filter=git-crypt diff=git-crypt  
/docs-finance/.meta/** filter=git-crypt diff=git-crypt

# docs-public bestanden zijn standaard niet versleuteld (geen expliciete regels nodig)

# Versleutel eventuele gevoelige .env bestanden
.env filter=git-crypt diff=git-crypt
.env.example !filter !diff

# Nooit versleutelen
.gitattributes !filter !diff
.gitignore !filter !diff
README.md !filter !diff
CLAUDE.md !filter !diff
