#!/bin/bash
# GitHub Actions run status monitor voor Kroescontrol Docs
# Toont laatste runs en volgt de meest recente
# 
# Usage: 
#   ./gh-run-status           - Monitor huidige runs (one-shot)
#   ./gh-run-status --watch   - Continue monitoring voor nieuwe builds

# Colors
GREEN='\033[1;32m'
BLUE='\033[1;34m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
PURPLE='\033[1;35m'
NC='\033[0m'

# Check for parameters
WATCH_MODE=false
if [[ "$1" == "--watch" ]]; then
    WATCH_MODE=true
elif [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
    echo "GitHub Actions deployment monitor voor Kroescontrol Docs"
    echo ""
    echo "Usage:"
    echo "  $0                Monitor huidige deployment run (one-shot)"
    echo "  $0 --watch        Continue monitoring voor nieuwe builds"
    echo "  $0 --help         Toon deze help"
    echo ""
    echo "In watch mode:"
    echo "  • Check elke 10 seconden voor nieuwe deployment runs"
    echo "  • Automatisch live monitoring van nieuwe actieve runs"
    echo "  • Verwerkt zowel success als failure scenarios"
    echo "  • Druk Ctrl+C om te stoppen"
    echo ""
    echo "Workflows die gemonitord worden:"
    echo "  • Deploy Public Site"
    echo "  • Deploy to Vercel"
    exit 0
fi

echo -e "${BLUE}🔄 Monitoring GitHub Actions voor deployment workflows...${NC}"
if [[ "$WATCH_MODE" == "true" ]]; then
    echo -e "${PURPLE}👁️  Continue monitoring mode - druk Ctrl+C om te stoppen${NC}"
fi
echo "========================================================="

# Function to process completed runs
process_completed_run() {
    local run_id=$1
    
    if [ -z "$run_id" ]; then
        echo -e "${RED}❌ Geen run ID gespecificeerd voor processing${NC}"
        return 1
    fi
    
    run_status=$(gh run view $run_id --json conclusion --jq '.conclusion // ""' 2>/dev/null)
    
    if [ -z "$run_status" ]; then
        echo -e "${YELLOW}⚠️  Kon run status niet ophalen voor run $run_id${NC}"
        return 1
    fi
    
    if [ "$run_status" = "success" ]; then
        echo ""
        echo -e "${GREEN}✅ Run completed successfully! Checking Vercel deployment logs...${NC}"
        
        # Check if this was a Vercel deployment
        workflow_name=$(gh run view $run_id --json workflowName --jq '.workflowName')
        
        if [ "$workflow_name" = "Deploy to Vercel" ]; then
            echo ""
            echo -e "${BLUE}🔍 Running vercel inspect --logs...${NC}"
            echo "=========================================="
            
            # Get the latest Vercel deployment ID
            vercel_deployment=$(vercel ls --limit 1 --format plain | head -n 1 | awk '{print $1}')
            
            if [ ! -z "$vercel_deployment" ]; then
                echo "📍 Inspecting deployment: $vercel_deployment"
                vercel inspect --logs "$vercel_deployment"
                
                echo ""
                echo -e "${BLUE}📋 Running vercel logs...${NC}"
                echo "========================="
                vercel logs "$vercel_deployment"
            else
                echo "⚠️  Geen Vercel deployment gevonden"
            fi
        else
            echo "ℹ️  Dit was geen Vercel deployment, Vercel logs overgeslagen"
        fi
    elif [ "$run_status" = "failure" ]; then
        echo ""
        echo -e "${RED}❌ Build FAILED! Analysing error logs...${NC}"
        echo "=========================================="
        
        # Get run details
        run_info=$(gh run view $run_id --json workflowName,conclusion,jobs --jq '{workflow: .workflowName, conclusion: .conclusion, jobs: .jobs}')
        workflow_name=$(echo "$run_info" | jq -r '.workflow')
        
        echo -e "${YELLOW}📋 Workflow: $workflow_name${NC}"
        echo -e "${YELLOW}📋 Status: $(echo "$run_info" | jq -r '.conclusion')${NC}"
        echo ""
        
        # Get failed jobs
        failed_jobs=$(echo "$run_info" | jq -r '.jobs[] | select(.conclusion == "failure") | .name')
        
        if [ ! -z "$failed_jobs" ]; then
            echo -e "${RED}💥 Failed Jobs:${NC}"
            echo "$failed_jobs" | while read job_name; do
                echo "  • $job_name"
            done
            echo ""
            
            # Get detailed logs for each failed job
            echo -e "${YELLOW}📖 Error Details (laatste 10 regels per job):${NC}"
            echo "================================================="
            
            echo "$failed_jobs" | while read job_name; do
                echo ""
                echo -e "${BLUE}🔍 Job: $job_name${NC}"
                echo "----------------------------------------"
                
                # Get job logs (laatste 10 regels)
                job_logs=$(gh run view $run_id --log | grep -A 20 "$job_name" | tail -n 10)
                
                if [ ! -z "$job_logs" ]; then
                    echo "$job_logs"
                else
                    echo "⚠️  Geen logs gevonden voor job: $job_name"
                    echo "💡 Probeer: gh run view $run_id --log"
                fi
            done
        else
            echo -e "${YELLOW}⚠️  Geen specifieke failed jobs gevonden${NC}"
            echo ""
            echo -e "${BLUE}📖 Run logs (laatste 15 regels):${NC}"
            echo "=================================="
            gh run view $run_id --log | tail -n 15
        fi
        
        echo ""
        echo -e "${YELLOW}💡 Voor volledige logs: gh run view $run_id --log${NC}"
        echo -e "${YELLOW}💡 Voor job details: gh run view $run_id${NC}"
        
    else
        echo ""
        echo -e "${YELLOW}⚠️  Run status: $run_status${NC}"
        
        if [ "$run_status" = "cancelled" ]; then
            echo "ℹ️  Run werd geannuleerd"
        elif [ "$run_status" = "skipped" ]; then
            echo "ℹ️  Run werd overgeslagen"
        elif [ "$run_status" = "neutral" ]; then
            echo "ℹ️  Run had neutrale uitkomst"
        fi
    fi
}

# Function to get latest run info
get_latest_run() {
    public_run=$(gh run list --workflow="Deploy Public Site" --limit 1 --json databaseId,createdAt --jq '.[0] // empty')
    vercel_run=$(gh run list --workflow="Deploy to Vercel" --limit 1 --json databaseId,createdAt --jq '.[0] // empty')
    
    latest_run=""
    latest_workflow=""
    
    if [ ! -z "$public_run" ] && [ ! -z "$vercel_run" ]; then
        public_time=$(echo "$public_run" | jq -r '.createdAt')
        vercel_time=$(echo "$vercel_run" | jq -r '.createdAt')
        
        if [[ "$public_time" > "$vercel_time" ]]; then
            latest_run=$(echo "$public_run" | jq -r '.databaseId')
            latest_workflow="Deploy Public Site"
        else
            latest_run=$(echo "$vercel_run" | jq -r '.databaseId')
            latest_workflow="Deploy to Vercel"
        fi
    elif [ ! -z "$public_run" ]; then
        latest_run=$(echo "$public_run" | jq -r '.databaseId')
        latest_workflow="Deploy Public Site"
    elif [ ! -z "$vercel_run" ]; then
        latest_run=$(echo "$vercel_run" | jq -r '.databaseId')
        latest_workflow="Deploy to Vercel"
    fi
}

# Function to show recent runs
show_recent_runs() {
    echo -e "${YELLOW}📋 Deploy Public Site (laatste 2):${NC}"
    gh run list --workflow="Deploy Public Site" --limit 2
    
    echo ""
    echo -e "${YELLOW}📋 Deploy to Vercel (laatste 2):${NC}"
    gh run list --workflow="Deploy to Vercel" --limit 2
    echo ""
}

# Function to monitor a specific run
monitor_run() {
    local run_id=$1
    local workflow_name=$2
    
    echo -e "${GREEN}👀 Watching: $workflow_name${NC}"
    echo ""
    echo -e "${BLUE}🔄 Live status monitoring...${NC}"
    echo "============================="
    
    # Start live monitoring in a loop
    while true; do
        # Get current status with error handling
        run_info=$(gh run view $run_id --json status,conclusion,workflowName 2>/dev/null)
        if [ $? -ne 0 ] || [ -z "$run_info" ]; then
            echo -e "\n${RED}❌ Fout bij ophalen run info voor run $run_id${NC}"
            break
        fi
        
        current_status=$(echo "$run_info" | jq -r '.status // "unknown"' 2>/dev/null)
        current_conclusion=$(echo "$run_info" | jq -r '.conclusion // ""' 2>/dev/null)
        
        # Fallback check if jq fails
        if [ -z "$current_status" ] || [ "$current_status" = "null" ]; then
            current_status="unknown"
        fi
        
        # Clear previous line and show current status  
        printf "\r\033[K${YELLOW}📊 Status: %s${NC}" "$current_status"
        if [ ! -z "$current_conclusion" ] && [ "$current_conclusion" != "null" ]; then
            if [ "$current_conclusion" = "success" ]; then
                printf "\r\033[K${GREEN}✅ Status: completed successfully${NC}\n"
            elif [ "$current_conclusion" = "failure" ]; then
                printf "\r\033[K${RED}❌ Status: failed${NC}\n"
            else
                printf "\r\033[K${YELLOW}⚠️  Status: %s${NC}\n" "$current_conclusion"
            fi
            break
        fi
        
        # If still running, show jobs status
        if [ "$current_status" = "in_progress" ]; then
            printf "\n${BLUE}📋 Jobs status:${NC}\n"
            
            jobs_info=$(gh run view $run_id --json jobs --jq '.jobs[] | {name: .name, status: .status, conclusion: .conclusion}' 2>/dev/null)
            
            if [ ! -z "$jobs_info" ]; then
                echo "$jobs_info" | jq -r '"  • " + .name + ": " + .status + (if .conclusion != "" and .conclusion != null then " (" + .conclusion + ")" else "" end)' 2>/dev/null
                job_count=$(echo "$jobs_info" | jq -s 'length' 2>/dev/null || echo "1")
            else
                echo "  Loading jobs..."
                job_count=1
            fi
            
            # Short pause to show jobs info
            sleep 2
            
            # Move cursor back up for next update (clear jobs section)
            for ((i=0; i<=$job_count+1; i++)); do
                printf "\033[A\033[K"
            done
        fi
        
        sleep 5
    done
    
    # Process the completed run
    process_completed_run $run_id
    return 0
}

# Main monitoring logic
if [[ "$WATCH_MODE" == "true" ]]; then
    # Continue monitoring mode
    last_monitored_run=""
    
    while true; do
        show_recent_runs
        get_latest_run
        
        if [ ! -z "$latest_run" ]; then
            # Check if this is a new run OR if the current run is still active
            run_status=$(gh run view $latest_run --json status --jq '.status')
            
            if [ "$latest_run" != "$last_monitored_run" ]; then
                echo -e "${PURPLE}🆕 Nieuwe run gedetecteerd!${NC}"
                
                # Check if run is still active
                if [ "$run_status" = "in_progress" ] || [ "$run_status" = "queued" ]; then
                    monitor_run $latest_run "$latest_workflow"
                    last_monitored_run=$latest_run
                else
                    echo -e "${YELLOW}ℹ️  Run al voltooid: $run_status${NC}"
                    last_monitored_run=$latest_run
                fi
            elif [ "$run_status" = "in_progress" ] || [ "$run_status" = "queued" ]; then
                # Same run but still active - continue monitoring
                echo -e "${BLUE}🔄 Run nog steeds actief, verder monitoren...${NC}"
                monitor_run $latest_run "$latest_workflow"
            else
                echo -e "${BLUE}💤 Wachten op nieuwe builds... (check elke 10 sec)${NC}"
                sleep 10
                continue
            fi
        else
            echo -e "${YELLOW}⚠️  Geen deployment runs gevonden${NC}"
            echo -e "${BLUE}💤 Wachten op nieuwe builds... (check elke 10 sec)${NC}"
            sleep 10
            continue
        fi
        
        # After monitoring completes, process the results
        if [ ! -z "$latest_run" ]; then
            process_completed_run $latest_run
        fi
        
        echo ""
        echo -e "${PURPLE}🔄 Returning to monitoring mode...${NC}"
        echo "========================================="
        sleep 10  # Short pause before next check
    done
else
    # One-shot mode (original behavior)
    show_recent_runs
    get_latest_run
    
    if [ ! -z "$latest_run" ]; then
        echo -e "${GREEN}👀 Watching: $latest_workflow${NC}"
        
        # Check if run is still active
        run_status=$(gh run view $latest_run --json status --jq '.status')
        if [ "$run_status" = "in_progress" ] || [ "$run_status" = "queued" ]; then
            monitor_run $latest_run "$latest_workflow"
        else
            echo -e "${YELLOW}ℹ️  Run al voltooid: $run_status${NC}"
        fi
        
        # Process results
        run_status=$(gh run view $latest_run --json conclusion --jq '.conclusion')
        process_completed_run $latest_run
    else
        echo "⚠️  Geen deployment runs gevonden"
        echo "💡 Deployment workflows: 'Deploy Public Site' en 'Deploy to Vercel'"
    fi
fi
