# KroesControl Documentation Environment Configuration
# Copy this file to .env and fill in the values

# OpenAI API Key for documentation generation (optional)
# Required only if you want to enable the chat page functionality
OPENAI_API_KEY=your_openai_api_key_here

# Content Configuration
# Set to true for public-only mode (excludes internal, finance, operation docs)
PUBLIC_ONLY=false

# Feature Toggles
# Enable/disable the AI chat page (requires OPENAI_API_KEY)
ENABLE_CHAT_PAGE=false

# Enable extra LinkedIn meta tags for better social sharing
ENABLE_EXTRA_META_TAGS=false

# Site Configuration
# Base URL for the site (use "/" for root, or "/repo-name/" for GitHub Pages)
BASE_URL=/