# KroesControl Documentation Environment Configuration
# Copy this file to .env and fill in the values

# OpenAI API Key for documentation generation
OPENAI_API_KEY=your_openai_api_key_here

# Deployment Configuration
# Set to "public" for public-only deployment or "full" for complete deployment
DEPLOYMENT_MODE=public

# Site Configuration
SITE_URL=https://public.kroescontrol.nl