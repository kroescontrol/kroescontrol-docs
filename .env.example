# Kroescontrol Documentatie Omgeving Configuratie
# Kopieer dit bestand naar .env en vul de waarden in

# OpenAI API sleutel voor documentatie generatie
OPENAI_API_KEY=jouw_openai_api_sleutel_hier

# Deployment Configuratie
# Zet op "public" voor alleen publieke deployment of "full" voor complete deployment
DEPLOYMENT_MODE=public

# Site Configuratie
SITE_URL=https://docs.kroescontrol.nl

# Pre-commit Validatie
# Zet op "true" om Post Keyboard Hoek validatie in te schakelen bij pre-commit hooks
ENABLE_PRE_COMMIT_VALIDATION=false